<%- include('partials/header') %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mt-4 gap-3">
  <div>
    <h1 class="h3 mb-1">Welcome, <%= currentUser.name %></h1>
    <p class="text-muted mb-0">UPI ID: <strong><%= currentUser.upi_id %></strong></p>
  </div>
  <a href="/upi/pay" class="btn btn-primary">Send Money</a>
</div>

<div class="row g-3 mt-2">
  <div class="col-md-4">
    <div class="stat-card">
      <span>Total Balance</span>
      <strong>Rs. <%= Number(totalBalance).toFixed(2) %></strong>
    </div>
  </div>
  <div class="col-md-4">
    <div class="stat-card">
      <span>Linked Accounts</span>
      <strong><%= accounts.length %></strong>
    </div>
  </div>
  <div class="col-md-4">
    <div class="stat-card">
      <span>Recent Transactions</span>
      <strong><%= recentTransactions.length %></strong>
    </div>
  </div>
</div>

<section class="mt-4">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="h5 mb-0">Linked Bank Accounts</h2>
    <a href="/bank/add-account" class="btn btn-sm btn-outline-primary">Add Account</a>
  </div>
  <div class="table-responsive surface">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Account No</th>
          <th>Bank</th>
          <th>IFSC</th>
          <th>Balance</th>
        </tr>
      </thead>
      <tbody>
        <% if (accounts.length === 0) { %>
          <tr><td colspan="4" class="text-center text-muted">No linked accounts.</td></tr>
        <% } %>
        <% accounts.forEach(account => { %>
          <tr>
            <td><%= account.account_no %></td>
            <td><%= account.bank_name %></td>
            <td><%= account.ifsc_code %></td>
            <td>Rs. <%= Number(account.balance).toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="mt-4">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="h5 mb-0">Recent Transactions</h2>
    <a href="/transaction/history" class="btn btn-sm btn-outline-primary">View All</a>
  </div>
  <div class="table-responsive surface">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Reference</th>
          <th>Type</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% if (recentTransactions.length === 0) { %>
          <tr><td colspan="5" class="text-center text-muted">No transactions yet.</td></tr>
        <% } %>
        <% recentTransactions.forEach(transaction => { %>
          <tr>
            <td><%= transaction.reference_no %></td>
            <td><%= transaction.sender_id === currentUser.user_id ? 'Sent' : 'Received' %></td>
            <td>Rs. <%= Number(transaction.amount).toFixed(2) %></td>
            <td><span class="badge status-<%= transaction.status.toLowerCase() %>"><%= transaction.status %></span></td>
            <td><%= new Date(transaction.created_at).toLocaleString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
