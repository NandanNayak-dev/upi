<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mt-4 mb-3">
  <h1 class="h3 mb-0">Linked Accounts</h1>
  <a href="/bank/add-account" class="btn btn-primary">Add Account</a>
</div>

<div class="table-responsive surface">
  <table class="table align-middle mb-0">
    <thead>
      <tr>
        <th>Account No</th>
        <th>Bank</th>
        <th>IFSC</th>
        <th>Balance</th>
        <th>Linked On</th>
      </tr>
    </thead>
    <tbody>
      <% if (accounts.length === 0) { %>
        <tr><td colspan="5" class="text-center text-muted">No bank accounts linked.</td></tr>
      <% } %>
      <% accounts.forEach(account => { %>
        <tr>
          <td><%= account.account_no %></td>
          <td><%= account.bank_name %></td>
          <td><%= account.ifsc_code %></td>
          <td>Rs. <%= Number(account.balance).toFixed(2) %></td>
          <td><%= new Date(account.created_at).toLocaleDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>
